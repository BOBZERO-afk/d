echo %version%
SET "result=%version:~1%"
SET minwingetversionA=1
SET minwingetversionB=11
for /f "tokens=1,2 delims=." %%a in ("%result%") do (
    set "resultA=%%a"
    set "resultB=%%b"
)
if %resultA% LEQ %minwingetversionA% (
	if %resultB% LSS %minwingetversionB% (
		call :InstallWinget
	)
)
